{
  "name": "sebastienkeroack-portfolio",
  "version": "0.4.1",
  "description": "This project is a custom-built website designed to host and showcase a multilingual personal portfolio.",
  "author": "Sébastien Kéroack",
  "repository": {
    "type": "git",
    "url": "https://github.com/SebastienKeroack/sebastienkeroack-portfolio.git"
  },
  "keywords": [
    "portfolio",
    "multilingual",
    "frontend",
    "backend",
    "web development",
    "css",
    "html",
    "javascript",
    "php",
    "ssi"
  ],
  "devDependencies": {
    "@3c1u/bun-run-all": "^0.1.2",
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^10.0.1",
    "@prettier/plugin-php": "^0.24.0",
    "bun-types": "^1.3.10",
    "esbuild": "^0.27.4",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "html-minifier-terser": "^7.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "w3c-html-validator": "^2.2.0"
  },
  "scripts": {
    "build": "bun run core/bun/src/build.mjs",
    "build:version": "bun run core/bun/src/bump-version.mjs",
    "lint:eslint": "eslint --config core/bun/eslint.config.js .",
    "lint:prettier": "prettier --config core/bun/.prettierrc.yaml --ignore-path core/bun/.prettierignore --check --cache .",
    "lint:phpcs": "php core/php/vendor/bin/phpcs --standard=core/php/phpcs.xml",
    "lint:stylelint": "stylelint --config core/bun/.stylelintrc.yaml --ignore-path .gitignore core/public_html/**/*.css",
    "lint:html-validator": "html-validator --ignore-config=core/bun/.w3c-ignore --continue core/public_html",
    "lint:all": "run-p --continue-on-error lint:eslint lint:prettier lint:phpcs lint:stylelint lint:html-validator",
    "fix:eslint": "bun run lint:eslint --fix",
    "fix:prettier": "bun run lint:prettier --write",
    "fix:phpcs": "php core/php/vendor/bin/phpcbf --standard=core/php/phpcs.xml",
    "fix:stylelint": "bun run lint:stylelint --fix",
    "fix:all": "run-s --continue-on-error fix:eslint fix:prettier fix:phpcs fix:stylelint",
    "test:php": "php core/php/vendor/bin/pest --configuration=core/php/phpunit.xml --colors=always --test-directory=test",
    "test:all": "bun test; bun run test:php",
    "prepare": "husky"
  },
  "license": "Apache-2.0"
}

{
  "files.associations": {
    "settings_recommended.json": "jsonc",
    ".w3c-ignore": "ignore"
  },
  "files.exclude": {
    "**/*.lock": true,
    "**/node_modules": true,
    "**/vendor": true
  },
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,
  "editor.formatOnSave": true,
  "editor.insertSpaces": true,
  "search.useIgnoreFiles": true,
  "search.useParentIgnoreFiles": true,
  // ===========================================================================
  // --- Formatter settings
  //
  "[css][javascript][json][markdown][php][yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "prettier.configPath": "core/bun/.prettierrc.yaml",
  "prettier.ignorePath": "core/bun/.prettierignore",
  "prettier.experimentalTernaries": true,
  "prettier.documentSelectors": ["**/*.{css,js,json,md,php,yaml}"],
  // ===========================================================================
  // --- GitHub Copilot settings
  "github.copilot.chat.commitMessageGeneration.instructions": [
    {
      "text": "Use Conventional Commits: type(scope): subject"
    },
    {
      "text": "Types: feat, fix, docs, style, refactor, perf, test, chore, ci"
    },
    {
      "text": "Subject: imperative mood, no trailing period, keep it short"
    },
    {
      "text": "Scope: use when helpful; lowercase; omit if not needed"
    },
    {
      "text": "If adding body/footer: separate with blank lines; reference issues as #123"
    },
    {
      "text": "Avoid listing individual changes as bullets; for large PRs describe review order, otherwise omit body"
    },
    {
      "text": "Example: feat(parser): add support for new syntax"
    }
  ]
}
